#!/bin/bash
# Install and configure keyd for Mac keyboard support

set -e

echo "Setting up keyd for Mac keyboard support..."

# Create keyd config directory if it doesn't exist
sudo mkdir -p /etc/keyd

# Copy keyd configuration
sudo tee /etc/keyd/default.conf > /dev/null << 'EOF'
[ids]
*

[main]
# Swap Alt and Meta: physical Command becomes Super, physical Option becomes Alt
leftalt = overload(mac, leftmeta)
leftmeta = leftalt

[mac:M]
# Common Mac shortcuts
c = C-c          # Copy
v = C-v          # Paste
x = C-x          # Cut
a = C-a          # Select all
z = C-z          # Undo
s = C-s          # Save
f = C-f          # Find
n = C-n          # New
o = C-o          # Open
w = C-w          # Close tab/window
t = C-t          # New tab
r = C-r          # Reload/Refresh

# Additional common Mac shortcuts
b = C-b          # Bold
i = C-i          # Italic  
u = C-u          # Underline
k = C-k          # Delete to end of line / Insert link
l = C-l          # Select line / Go to line
d = C-d          # Duplicate line / Add to selection
g = C-g          # Find next
h = C-h          # Replace / History
slash = C-slash  # Toggle comment
comma = C-comma  # Preferences (Ctrl+,)

# Text navigation (Mac style)
left = home      # Command+Left = Home
right = end      # Command+Right = End
up = C-home      # Command+Up = Start of document
down = C-end     # Command+Down = End of document
backspace = C-u  # Command+Backspace = Delete to start of line
EOF

echo "keyd configuration installed to /etc/keyd/default.conf"
echo ""
echo "To enable keyd, run:"
echo "  sudo systemctl enable --now keyd"
echo ""
echo "Note: Make sure your Keychron K8 is in PC mode (Fn+S+O for 3 seconds)"
