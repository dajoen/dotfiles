        "on-click": "blueman-manager",
        "format-no-controller": ""
    },
    "user": {
        "format": "{user}",
        "interval": 60,
        "icon": false
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": [
            "ţÄŹ",
            "ţĆö",
            "ţĆô",
            "ţĆĺ",
            "ţĆĹ",
            "ţĆÉ",
            "ţĆĆ",
            "ţĆÄ",
            "ţĆŹ",
            "ţĆî",
            "ţĆő",
            "ţĆŐ",
            "ţĆë",
            "ţĆł",
            "ţÄŤ"
        ],
        "scroll-step": 1
    }
}