{
    "hyprland/workspaces": {
        "on-scroll-up": "hyprctl dispatch workspace r-1",
        "on-scroll-down": "hyprctl dispatch workspace r+1",
        "on-click": "activate",
        "active-only": false,
        "all-outputs": true,
        "format": "{}",
        "format-icons": {
            "urgent": "",
            "active": "",
            "default": ""
        },
        "persistent-workspaces": {
            "*": 5
        }
    },
    "hyprland/window": {
        "max-length": 60,
        "separate-outputs": true
    },
    "custom/empty": {
        "format": ""
    },
    "custom/appmenu": {
        "format": "Apps",
        "on-click": "wofi --show drun",
        "tooltip-format": "Open the application launcher"
    },
    "custom/exit": {
        "format": "´ÇĹ",
        "on-click": "~/.local/bin/powermenu",
        "tooltip-format": "Power menu"
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:%H:%M %a}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "format": "´őŤ {usage}% ",
        "on-click": "kitty btop"
    },
    "memory": {
        "format": "´âë {}% ",
        "on-click": "kitty btop"
    },
    "disk": {
        "interval": 30,
        "format": "´éá {percentage_used}% ",
        "path": "/",
        "on-click": "kitty btop"
    },
    "hyprland/language": {
        "format": "´äť {short}"
    },
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "disk",
            "cpu",
            "memory",
            "hyprland/language"
        ]
    },
    "network": {
        "format": "{ifname}",
        "format-wifi": "´çź  {signalStrength}%",
        "format-ethernet": "´×ľ  {ifname}",
        "format-disconnected": "Disconnected ÔÜá",
        "tooltip-format": "´×ľ {ifname} via {gwaddr}",
        "tooltip-format-wifi": "´çź  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz",
        "tooltip-format-ethernet": "´×ľ {ifname}\nIP: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },
    "battery": {
        "interval": 1,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "´Śž  {capacity}%",
        "format-plugged": "´çŽ  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": [
            "´ëä ",
            "´ëâ ",
            "´ëé ",
            "´ëü ",
            "´ëÇ "
        ]
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
        "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
        "format-muted": "´Üę {format_source}",
        "format-source": "{volume}% ´ä░",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą ",
            "hands-free": "´ľÉ ",
            "headset": "´ľÉ ",
            "phone": "´éĽ ",
            "portable": "´éĽ ",
            "car": "´ć╣ ",
            "default": [
                "´ÇŽ",
                "´ÇĘ",
                "´ÇĘ"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "´Őô {status}",
        "format-disabled": "",
        "format-off": "",
